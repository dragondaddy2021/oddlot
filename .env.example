# Copy this file to .env and fill in every value.
# NEVER commit .env to version control.

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Upstash Redis ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# ── Auth ──────────────────────────────────────────────────────────────────────
# JWT verification uses Supabase JWKS (public key, derived from SUPABASE_URL).
# No JWT_SECRET needed.
# Random secret used to authenticate internal cron/webhook calls.
INTERNAL_CRON_SECRET=

# ── FinMind ───────────────────────────────────────────────────────────────────
FINMIND_API_TOKEN=

# ── CORS (comma-separated list of allowed frontend origins) ───────────────────
ALLOWED_ORIGINS=http://localhost:5173

# ── Frontend (Vite — vars must be prefixed with VITE_) ────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
